# Server
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Database (MySQL InnoDB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=kotak_neo_saas
DB_CONNECTION_LIMIT=50

# JWT / Sessions
JWT_SECRET=replace-with-64-char-random-string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
SESSION_SECRET=replace-with-32-char-random-string

# AES-256 encryption key for broker tokens (must be 64 hex chars / 32 bytes)
TOKEN_ENC_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Kotak Neo Trade API
# Login lives on mis.kotaksecurities.com; the per-user trading baseUrl is
# returned by tradeApiValidate (e.g. https://cis.kotaksecurities.com).
KOTAK_LOGIN_URL=https://mis.kotaksecurities.com
KOTAK_API_BASE=https://gw-napi.kotaksecurities.com
# Plain access token from NEO App → Invest → Trade API → Your Applications.
# Used as-is in Authorization header (no "Bearer " prefix).
KOTAK_API_TOKEN=
KOTAK_NEO_FIN_KEY=neotradeapi

# Worker
WORKER_ID=worker-1
WORKER_POLL_MS=200
WORKER_BATCH_SIZE=5
JOB_MAX_RETRIES=3
JOB_LOCK_TIMEOUT_MS=60000

# Rate limit (broker API): 10 req/sec per user
BROKER_RPS=10

# WebSocket
WS_MAX_SYMBOLS=200
