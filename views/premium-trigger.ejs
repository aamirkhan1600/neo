<script>
document.addEventListener('DOMContentLoaded', function () {
  const $err = document.getElementById('err');
  const $status = document.getElementById('status');
  const $meta = document.getElementById('meta');
  const $toggle = document.getElementById('toggleBtn');
  const $exit = document.getElementById('exitBtn');
  const $rce = document.getElementById('restrikeCe');
  const $rpe = document.getElementById('restrikePe');

  const fmtMoney = (v) => v == null ? '—' : (v >= 0 ? '₹' : '-₹') + Math.abs(v).toFixed(2);
  const fmtPts = (v) => v == null ? '—' : (v >= 0 ? '+' : '') + v.toFixed(2);
  const fmtPct = (v) => v == null ? '—' : v.toFixed(1) + '%';
  const lastLtp = { ce: null, pe: null };
  const legTokens = { ce: null, pe: null };
  // Snapshot of last /status response per leg — let the live tick
  // listener recompute Unrealized P&L on each tick instead of waiting
  // for the next /status poll. Without this, in-trade Unrealized lags
  // up to 500ms behind LTP and can briefly flash ₹0.00 right after an
  // entry fires (when entryPrice and ltp briefly equal each other).
  const legSnap = { ce: null, pe: null };

  // Live LTP via socket.io — every tick the server's marketData client
  // emits is forwarded to this user's room. We update the LTP cell as
  // ticks arrive (instant) instead of waiting for the /status poll, and
  // also recompute the Unrealized P&L cell so it tracks the live price.
  // reconnection: true ensures the socket rebuilds the cookie-auth handshake
  // after a token refresh, so live ticks resume without a page reload.
  const socket = window.io ? io({ withCredentials: true, reconnection: true, reconnectionDelay: 1000 }) : null;
  if (socket) {
    socket.on('connect_error', (err) => {
      // 401 from the socket auth means the access_token expired between
      // poll attempts. Hit /refresh and reconnect once.
      if (String(err && err.message).toLowerCase().includes('unauthorized')) {
        fetch('/api/auth/refresh', { method: 'POST', credentials: 'include' })
          .then((r) => { if (r.ok) socket.connect(); });
      }
    });
    socket.on('tick', (t) => {
      if (!t || t.ltp == null) return;
      const tok = String(t.symbol);
      const side = tok === legTokens.ce ? 'ce' : tok === legTokens.pe ? 'pe' : null;
      if (!side) return;
      const ltp = Number(t.ltp);
      setLtpCell(side, ltp);
      const snap = legSnap[side];
      if (snap && snap.position === 'SHORT' && snap.entryPrice != null && snap.qty) {
        const card = document.getElementById(side === 'ce' ? 'legCe' : 'legPe');
        const unrealEl = card && card.querySelector('.unreal');
        if (unrealEl) unrealEl.textContent = fmtMoney((snap.entryPrice - ltp) * snap.qty);
      }
    });
  }

  // Apply a price update to one leg's LTP cell — used by both the
  // periodic /status pull (sets state-derived LTP) and the live socket.io
  // 'tick' stream (instant LTP updates between polls).
  const lastLtpChangeAt = { ce: null, pe: null };
  function setLtpCell(side, ltp) {
    if (ltp == null || !Number.isFinite(ltp)) return;
    const card = document.getElementById(side === 'ce' ? 'legCe' : 'legPe');
    const ltpEl = card && card.querySelector('.ltp');
    if (!ltpEl) return;
    const prev = lastLtp[side];
    ltpEl.textContent = ltp.toFixed(2);
    if (prev != null && ltp !== prev) {
      ltpEl.classList.remove('ltp-up', 'ltp-down');
      void ltpEl.offsetWidth;
      ltpEl.classList.add(ltp > prev ? 'ltp-up' : 'ltp-down');
      lastLtpChangeAt[side] = Date.now();
    } else if (prev == null) {
      lastLtpChangeAt[side] = Date.now();
    }
    lastLtp[side] = ltp;
  }
  // Refresh the "Xs ago" age annotation every second so a sticky LTP is
  // visibly stale even when no new ticks arrive.
  setInterval(() => {
    for (const side of ['ce', 'pe']) {
      const card = document.getElementById(side === 'ce' ? 'legCe' : 'legPe');
      const ageEl = card && card.querySelector('.ltpAge');
      if (!ageEl) continue;
      const at = lastLtpChangeAt[side];
      if (at == null) { ageEl.textContent = ''; continue; }
      const sec = Math.floor((Date.now() - at) / 1000);
      ageEl.textContent = sec === 0 ? '· just now'
                       : sec < 60 ? `· ${sec}s ago`
                       : `· ${Math.floor(sec / 60)}m ${sec % 60}s ago`;
      ageEl.style.color = sec > 10 ? '#dc2626' : ''; // red after 10s sticky
    }
  }, 1000);

  function setLeg(side, st) {
    const card = document.getElementById(side === 'ce' ? 'legCe' : 'legPe');
    const set = (cls, val) => { const el = card.querySelector('.' + cls); if (el) el.textContent = val; };
    set('sym', st.symbol || '—');
    set('strike', st.strike != null ? st.strike : '—');
    const pos = card.querySelector('.pos');
    pos.textContent = st.position || 'NONE';
    pos.classList.remove('SHORT', 'NONE');
    pos.classList.add(st.position || 'NONE');
    // LTP cell — flash green/red on tick changes so the operator can see
    // the price is live and which way it moved.
    if (st.token != null) legTokens[side] = String(st.token);
    legSnap[side] = {
      position: st.position,
      entryPrice: st.entryPrice != null ? Number(st.entryPrice) : null,
      qty: st.qty != null ? Number(st.qty) : null,
    };
    setLtpCell(side, st.ltp != null ? Number(st.ltp) : null);
    set('entry', st.entryPrice != null ? Number(st.entryPrice).toFixed(2) : '—');
    set('target', st.targetPrice != null ? Number(st.targetPrice).toFixed(2) : '—');
    set('sl', st.slPrice != null ? Number(st.slPrice).toFixed(2) : '—');
    set('unreal', fmtMoney(st.unrealized));
    set('real', fmtMoney(st.realizedPnl));
    set('wl', `${st.tradesWon || 0} / ${st.tradesLost || 0}`);
    const lastR = st.lastRestrikeAt ? new Date(st.lastRestrikeAt).toLocaleTimeString() : '—';
    set('restrikes', `${st.restrikeCount || 0} (last ${lastR})`);
    if (st.outsideWindowSince) {
      const sec = Math.floor((Date.now() - st.outsideWindowSince) / 1000);
      set('drift', `outside window ${sec}s` + (st.restrikeInProgress ? ' (restriking…)' : ''));
    } else {
      set('drift', st.restrikeInProgress ? 'restriking…' : 'in window');
    }
    set('armed', st.armed ? 'YES' : 'no');
    set('decision', st.lastDecision || '—');
    const brkRows = card.querySelectorAll('.brk-row');
    if (st.bracket) {
      brkRows.forEach(r => r.classList.remove('hidden'));
      const tgt = st.bracket.targetPrice != null ? Number(st.bracket.targetPrice).toFixed(2) : '—';
      const sl  = st.bracket.slTriggerPrice != null ? Number(st.bracket.slTriggerPrice).toFixed(2) : '—';
      set('brkStatus', `${st.bracket.status} · TGT ${tgt} / SL ${sl}`);
      set('brkSl',  st.bracket.slOrderId  || '—');
      set('brkTgt', st.bracket.targetOrderId || '—');
    } else {
      brkRows.forEach(r => r.classList.add('hidden'));
    }
  }

  // Wrapper: any /api fetch that 401s gets a token-refresh attempt and a
  // single retry. The access_token cookie has a 15-min TTL — without
  // this, a 15-min-old tab silently drops to "status fetch failed: 401"
  // and the LTPs / decision fields stop updating until a hard reload.
  let _refreshing = null;
  async function fetchWithRefresh(url, init) {
    init = init || {};
    init.credentials = init.credentials || 'include';
    let r = await fetch(url, init);
    if (r.status !== 401) return r;
    // Coalesce parallel refresh attempts into one network call.
    if (!_refreshing) {
      _refreshing = fetch('/api/auth/refresh', { method: 'POST', credentials: 'include' })
        .finally(() => { setTimeout(() => { _refreshing = null; }, 0); });
    }
    const refresh = await _refreshing;
    if (!refresh.ok) return r; // refresh itself failed — caller sees the 401
    return fetch(url, init);
  }

  async function refresh() {
    try {
      const r = await fetchWithRefresh('/api/premium-trigger/status');
      if (!r.ok) {
        $err.textContent = r.status === 401
          ? 'session expired — log in again at /auth/login'
          : 'status fetch failed: ' + r.status;
        return;
      }
      const s = await r.json();
      $err.textContent = s.lastError || '';
      $toggle.textContent = s.running ? 'Stop' : 'Start';
      $toggle.dataset.on = s.running ? '1' : '0';
      $status.textContent = s.running ? 'RUNNING' : (s.enabled ? 'ENABLED (idle)' : 'DISABLED');
      $status.className = 'text-sm font-medium ml-auto ' + (s.running ? 'ok' : (s.enabled ? 'text-amber-600' : 'muted'));
      const $mb = document.getElementById('modeBadge');
      const isLive = s.cfg.mode === 'live';
      $mb.textContent = isLive ? 'LIVE' : 'PAPER';
      $mb.className = 'mode-badge ' + (isLive ? 'mode-live' : 'mode-paper');
      $mb.title = isLive ? 'LIVE — real orders are sent to Kotak Neo' : 'PAPER — fills are simulated locally; no broker call';
      // Reflect server's autoRestrikeOnDrift on the toggle. The checkbox
      // is only meaningful in OTM strike mode — disable it otherwise so
      // the operator knows it has no effect on ATM/fixed configs.
      const isOtm = s.cfg.strikeMode === 'otm';
      $autoRestrike.disabled = !isOtm;
      $autoRestrike.parentElement.title = isOtm
        ? 'When ON, a leg whose LTP drifts outside its rearm window for `restrikeDwellSec` seconds rotates to the closest OTM strike. Set in /premium-trigger/settings.'
        : 'Auto-restrike only applies in OTM strike mode (currently ' + (s.cfg.strikeMode || '?') + ')';
      $autoRestrike.parentElement.style.opacity = isOtm ? '' : '0.5';
      // Skip syncing while a manual click is mid-flight (checkbox is
      // already showing the operator's intent).
      if (document.activeElement !== $autoRestrike) {
        $autoRestrike.checked = !!s.cfg.autoRestrikeOnDrift;
      }
      $meta.innerHTML = [
        `Underlying <strong class="text-ink-900">${s.cfg.underlyingName}</strong>`,
        `Expiry <strong class="text-ink-900">${s.cfg.expiry || 'auto'}</strong>`,
        `Strike mode <strong class="text-ink-900">${s.cfg.strikeMode}</strong>`,
        `Spot <strong class="text-ink-900">${s.spot != null ? Number(s.spot).toFixed(2) : '—'}</strong>`,
        `Last tick <strong class="text-ink-900">${s.lastTickAt ? new Date(s.lastTickAt).toLocaleTimeString() : '—'}</strong>`,
        s.dayLossLocked ? '<span class="bad font-semibold">DAY-LOSS LOCKED</span>' : '',
      ].filter(Boolean).map(x => `<span>${x}</span>`).join('');
      setLeg('ce', s.state.ce);
      setLeg('pe', s.state.pe);
      const $ws = document.getElementById('wsDiag');
      if (s.ws) {
        const ageFrame = s.ws.lastFrameAt ? Math.floor((Date.now() - s.ws.lastFrameAt) / 1000) + 's ago' : 'never';
        const ageTick  = s.ws.lastTickAt  ? Math.floor((Date.now() - s.ws.lastTickAt)  / 1000) + 's ago' : 'never';
        const agePoll  = s.ws.pollLastOk  ? Math.floor((Date.now() - s.ws.pollLastOk)  / 1000) + 's ago' : 'never';
        const isOpen   = s.ws.readyStateLabel === 'OPEN';
        const dataFlowing = s.ws.ticksEmitted > 0 || s.ws.pollLastOk;
        const tone     = dataFlowing ? 'text-emerald-700'
                       : isOpen ? 'text-amber-700' : 'text-rose-700';
        let warn = '';
        if (!dataFlowing) {
          if (!isOpen) warn = ' — WS not connected, restart strategy or re-login to broker';
          else if (s.ws.subsCount === 0) warn = ' — no subscriptions registered';
          else if (s.ws.pollErrors > 0) warn = ` — REST poll erroring: ${s.ws.pollLastError || 'unknown'}`;
          else if (s.ws.framesReceived === 0 && !s.ws.pollActive) warn = ' — gateway silent and REST poll disabled (set MARKET_DATA_POLL_MS=1000)';
          else if (s.ws.framesReceived === 0) warn = ' — WS gateway silent, waiting on REST poll…';
        }
        const pollBit = s.ws.pollActive
          ? `poll ${s.ws.pollCount}/${s.ws.pollErrors}err (last ok ${agePoll})`
          : 'poll off';
        $ws.classList.remove('hidden');
        $ws.className = 'text-xs mt-2 px-3 py-2 rounded border border-line bg-surface-muted ' + tone;
        $ws.textContent = `WS ${s.ws.readyStateLabel} · subs ${s.ws.subsCount} · frames ${s.ws.framesReceived} (last ${ageFrame}) · ticks ${s.ws.ticksEmitted} (last ${ageTick}) · ${pollBit}${warn}`;
      } else {
        $ws.classList.add('hidden');
      }
      document.getElementById('tRealized').textContent = fmtMoney(s.totalRealized);
      document.getElementById('tUnreal').textContent = fmtMoney(s.totalUnrealized);
      document.getElementById('tDD').textContent = fmtMoney(s.currentDrawdown) + ' / max ' + fmtMoney(s.maxDrawdown);
      document.getElementById('tTrades').textContent = s.totalTrades || 0;
      document.getElementById('tWL').textContent = `${s.totalWon || 0} / ${s.totalLost || 0}`;
      document.getElementById('tAcc').textContent = fmtPct(s.accuracy);
      document.getElementById('tPF').textContent = s.profitFactor == null ? '—'
        : (s.profitFactor === Infinity ? '∞' : Number(s.profitFactor).toFixed(2));
      document.getElementById('tCharges').textContent = fmtMoney(s.totalCharges);
      document.getElementById('tRestrikes').textContent = s.restrikeCount || 0;

      const sigs = s.signals || [];
      const tb = document.getElementById('signals');
      if (!sigs.length) {
        tb.innerHTML = '<tr><td colspan="9" class="muted center py-6">No signals yet.</td></tr>';
      } else {
        tb.innerHTML = sigs.map(sig => {
          const mode = (sig.mode || 'live').toUpperCase();
          const okStatus = sig.status === 'placed' || sig.status === 'paper-filled';
          const sideCls = String(sig.side).toLowerCase() === 'ce' ? 'ce-head' : 'pe-head';
          return `
          <tr>
            <td class="text-xs text-ink-500 whitespace-nowrap">${new Date(sig.at).toLocaleTimeString()}</td>
            <td><span class="mode-pill mode-${(sig.mode || 'live')}">${mode}</span></td>
            <td class="${sideCls} font-semibold uppercase">${sig.side}</td>
            <td>${sig.action}</td>
            <td>${sig.reason}</td>
            <td class="text-right tabular-nums">${Number(sig.price).toFixed(2)}</td>
            <td class="text-right tabular-nums">${sig.qty}</td>
            <td class="font-mono text-xs">${sig.symbol}</td>
            <td class="${okStatus ? 'ok' : sig.status === 'rejected' ? 'bad' : ''}">${sig.status}${sig.rejectReason ? ' — ' + sig.rejectReason : ''}</td>
          </tr>`;
        }).join('');
      }
    } catch (err) { $err.textContent = err.message; }
  }

  $toggle.addEventListener('click', async () => {
    const on = $toggle.dataset.on !== '1';
    const r = await fetchWithRefresh('/api/premium-trigger/toggle', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      credentials: 'include', body: JSON.stringify({ on }),
    });
    if (!r.ok) { const j = await r.json().catch(() => ({})); $err.textContent = j.message || j.error || 'toggle failed'; }
    refresh();
  });

  $exit.addEventListener('click', async () => {
    if (!confirm('Square off ALL open premium-trigger positions?')) return;
    await fetchWithRefresh('/api/premium-trigger/exit-all', { method: 'POST' });
    refresh();
  });

  $rce.addEventListener('click', async () => {
    const r = await fetchWithRefresh('/api/premium-trigger/restrike?side=ce', { method: 'POST' });
    const j = await r.json().catch(() => ({}));
    if (!r.ok) $err.textContent = j.message || j.error || 'restrike CE failed';
    refresh();
  });
  $rpe.addEventListener('click', async () => {
    const r = await fetchWithRefresh('/api/premium-trigger/restrike?side=pe', { method: 'POST' });
    const j = await r.json().catch(() => ({}));
    if (!r.ok) $err.textContent = j.message || j.error || 'restrike PE failed';
    refresh();
  });

  // Auto-restrike toggle — POSTs the same /settings endpoint the full
  // settings page uses. We send only the one field so other config
  // values stay untouched. The checkbox state is re-synced from the
  // server on every /status refresh so UI never drifts from truth.
  const $autoRestrike = document.getElementById('autoRestrikeToggle');
  $autoRestrike.addEventListener('change', async () => {
    const on = $autoRestrike.checked;
    const r = await fetchWithRefresh('/api/premium-trigger/settings', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ autoRestrikeOnDrift: on }),
    });
    const j = await r.json().catch(() => ({}));
    if (!r.ok) {
      $err.textContent = j.message || j.error || 'failed to update auto-restrike';
      $autoRestrike.checked = !on;  // revert on failure
    } else {
      $err.textContent = '';
    }
    refresh();
  });

  refresh();
  // 500ms refresh — server-side REST poll runs at MARKET_DATA_POLL_MS
  // (default 1000ms), but pulling at half that cadence keeps the LTP
  // visibly fresh even when one fetch happens to land between polls.
  setInterval(refresh, 500);
});
</script>

